# Secrets
.env

# Fetch cache (re-derivable from sources)
raw/*
!raw/.gitkeep

# Nested independent repo — its own GitHub root (michac/wow-planner-state).
# Ignored here so `git` at the wow root never sees it as an embedded repo.
/planner-state/

# MCP tool scratch (Playwright browser session artifacts)
.playwright-mcp/

# Local dev scratch (working notes, not KB content)
scratchpad/

# Python
__pycache__/
*.pyc
.venv/
tools/.venv/

# Dart / Flutter (trainer/)
build/
.dart_tool/
*.dart_tool/
.packages
trainer/sim/pubspec.lock
