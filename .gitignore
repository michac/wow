# Secrets
.env

# Fetch cache (re-derivable from sources)
raw/*
!raw/.gitkeep

# Nested independent repos — each its own GitHub root. Ignored here so `git` at
# the wow root never sees them as embedded repos.
# (gitignore has no inline comments — keep the pattern lines bare.)
# michac/wow-planner-state:
/planner-state/
# michac/BucketBinds (BucketBinds addon source):
/projects/keybinder/addon/
# archival xlsx re-import side file (diff-only; canonical seed is hand-maintained):
/projects/keybinder/data/bellular-keybinds.archive-import.json
# michac/CDMProbe (Cooldown Manager probe addon source):
/projects/cooldown-hud/addon/

# MCP tool scratch (Playwright browser session artifacts)
.playwright-mcp/

# Local dev scratch (working notes, not KB content)
scratchpad/

# Python
__pycache__/
*.pyc
.venv/
tools/.venv/

# Dart / Flutter (trainer/)
build/
.dart_tool/
*.dart_tool/
.packages
trainer/sim/pubspec.lock
