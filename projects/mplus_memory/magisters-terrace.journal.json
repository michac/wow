      "sections": [
        {
          "id": 30544,
          "title": "Overview",
          "body_text": "Seranel assaults players with [Suppression Zones] that cause [Feedback] to players affected by [Runic Mark].\r\n\r\nUpon reaching 100 energy, Seranel causes an [Wave of Silence] silencing and pacifying players outside of [Suppression Zones].",
          "sections": [
            {
              "id": 30545,
              "title": "Damage Dealers",
              "body_text": "$bullet;[Wave of Silence] inflicts heavy damage and silences players outside of [Suppression Zones].\r\n$bullet;[Runic Mark] inflicts moderate damage to nearby players.\r\n$bullet;[Suppression Zone] and [Feedback] silences and pacifies players."
            },
            {
              "id": 30546,
              "title": "Healers",
              "body_text": "$bullet;[Wave of Silence] inflicts heavy damage and silences players outside of [Suppression Zones].\r\n$bullet;[Runic Mark] inflicts moderate damage to nearby players.\r\n$bullet;[Suppression Zone] and [Feedback] silences and pacifies players."
            },
            {
              "id": 30547,
              "title": "Tanks",
              "body_text": "$bullet;[Hastening Ward] increases Seranel's attack speed and causes his melee attacks to inflict additional Arcane damage.\r\n$bullet;[Wave of Silence] inflicts heavy damage and silences players outside of [Suppression Zones].\r\n$bullet;[Runic Mark] inflicts moderate damage to nearby players."
            }
          ]
